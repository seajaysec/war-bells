{
  "title": "War Bells",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Granular / glitch /",
        "delay / looper FX.",
        "Pick an Effect +",
        "Variation, then",
        "shape with the 8",
        "knobs. Hold sampler,",
        "reverb, filter and a",
        "60s looper built in."
      ]
    },
    {
      "title": "Knobs",
      "lines": [
        "1 Effect",
        "2 Variation",
        "3 Activity (density)",
        "4 Repeats (length)",
        "5 Shape (tone)",
        "6 Mix (dry/wet)",
        "7 Space (reverb)",
        "8 Filter (lowpass)"
      ]
    },
    {
      "title": "Effects",
      "lines": [
        "Loops: Glide, Seq,",
        " Stack",
        "Grains: Cloud,",
        " Drone, Chain",
        "Glitch: Arp, Cutup,",
        " Chop",
        "Delays: Taps, Warp",
        "",
        "Variation re-labels",
        "per effect (oct+,",
        "line, casc, etc)."
      ]
    },
    {
      "title": "Pages",
      "lines": [
        "Tone: reso fx-vol",
        " grain-env scale",
        "Time: tempo subdiv",
        "Space FX: reverb",
        " shimmer width mod",
        "Motion: LFO -> macro",
        "Generate: evolve",
        " range dice",
        "Perform: reverse",
        " hold duck",
        "Looper: rec/play",
        "User Slots: save",
        "Config: in, bypass",
        "Trails = tail rings",
        " out on bypass",
        "Eco = lite reverb",
        " (CPU for stacks)"
      ]
    },
    {
      "title": "Alive",
      "lines": [
        "Shimmer: pitched",
        " reverb tail.",
        "Scale: keep grains",
        " in key.",
        "Motion: tempo LFO",
        " on any macro.",
        "Evolve: textures",
        " drift; Dice = now.",
        "Duck: blooms in",
        " the gaps."
      ]
    },
    {
      "title": "Saving",
      "lines": [
        "User Slots page:",
        "pick User Slot 1-16,",
        "then User Op:",
        "Save / Load / Del.",
        "",
        "Save stores all",
        "params AND the",
        "recorded loop.",
        "",
        "Whole-chain patches",
        "save via Schwung",
        "Manager too."
      ]
    },
    {
      "title": "Tips",
      "lines": [
        "Mix at 100% lets",
        "glitch fully cut",
        "the dry signal.",
        "",
        "Filter full up =",
        "wide open.",
        "",
        "Hold freezes the",
        "last moment into a",
        "sustained bed."
      ]
    }
  ]
}
